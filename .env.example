# Core Configuration
# Required for normal auth: Secret for signing JWT session cookies (min 32 chars recommended)
# (Not required for /demo path)
JWT_SECRET=

# AI Features
# Required for AI-powered insights (Gemini API)
# Get your key at: https://aistudio.google.com/app/apikey
NEXT_PUBLIC_GEMINI_API_KEY=

# Persistence Layer (Optional)
# ClientFlow defaults to local JSON persistence if these are missing.
# To use Supabase, provide these from your project settings.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Environment
NODE_ENV=development
