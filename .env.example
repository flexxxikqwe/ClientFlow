# Core Configuration
# Required: Secret for signing JWT session cookies (min 32 chars recommended)
JWT_SECRET=

# AI Features
# Required for AI-powered insights and lead scoring
NEXT_PUBLIC_GEMINI_API_KEY=

# Persistence Layer (Optional)
# ClientFlow falls back to local JSON persistence if these are missing.
# To use Supabase, provide these from your project settings.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Environment
NODE_ENV=development
